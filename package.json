{
  "name": "promptstack",
  "version": "1.0.0",
  "description": "Prompt version control for AI power users - save, version, compare, and optimize your prompts",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "promptstack": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "cli": "tsx src/cli.ts"
  },
  "keywords": [
    "prompt",
    "ai",
    "version-control",
    "llm",
    "prompt-engineering"
  ],
  "author": "Loki AI",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "diff": "^5.1.0",
    "express": "^5.2.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/diff": "^5.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
